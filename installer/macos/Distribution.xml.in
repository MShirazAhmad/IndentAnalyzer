<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
  <title>IndentAnalyzer</title>
  <organization>com.indentanalyzer</organization>
  <options customize="never" require-scripts="true" rootVolumeOnly="true" />
  <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true" />
  <welcome file="Welcome.txt" />
  <readme file="ReadMe.txt" />
  <license file="LICENSE.txt" />
  <pkg-ref id="com.indentanalyzer.app.pkg" version="@VERSION@" onConclusion="none">IndentAnalyzer-component.pkg</pkg-ref>
  <choices-outline>
    <line choice="default">
      <line choice="com.indentanalyzer.app.pkg" />
    </line>
  </choices-outline>
  <choice id="default" />
  <choice id="com.indentanalyzer.app.pkg" title="IndentAnalyzer" visible="false">
    <pkg-ref id="com.indentanalyzer.app.pkg" />
  </choice>
</installer-gui-script>
